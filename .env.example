WARTUNG_HOST=0.0.0.0
WARTUNG_PORT=8080
WARTUNG_DATA_DIR=/data
WARTUNG_BACKUP_DIR=/data/backups
WARTUNG_DB_PATH=/data/wartung.db
# Nur hinter einem vertrauenswürdigen Reverse Proxy aktivieren, z. B. Railway.
WARTUNG_TRUST_PROXY=1
WARTUNG_STATE_RECENT_LOG_LIMIT=1000
WARTUNG_STATE_RECENT_NOTE_LIMIT=500
TEAMLEITER_CODE=bitte-aendern

# Nur kurzzeitig zum Reparieren des Produktions-Adminzugangs setzen.
# Danach wieder aus Railway entfernen, sonst wird das Passwort bei jedem Start neu gesetzt.
WARTUNG_BOOTSTRAP_ADMIN_EMAIL=admin@example.org
WARTUNG_BOOTSTRAP_ADMIN_NAME=Admin
WARTUNG_BOOTSTRAP_ADMIN_PASSWORD=bitte-aendern-123
